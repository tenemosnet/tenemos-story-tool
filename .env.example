# ===================================================
# tenemos-story-tool 環境変数サンプル
# このファイルを .env.local にコピーして実際の値を入力してください
# .env.local は絶対にGitにコミットしないでください
# ===================================================

# Claude APIキー（https://console.anthropic.com）
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase（https://supabase.com）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# アプリパスワード（共有ログイン認証）
APP_PASSWORD=your_password

# 週次自動生成 Bearer認証キー
CRON_SECRET=your_cron_secret

# GAS メール通知（任意）
# GAS_WEBHOOK_URL=https://script.google.com/macros/s/xxx/exec
# GAS_WEBHOOK_SECRET=your_gas_secret

# Claude API 料金計算（オプション、デフォルト値あり）
# 公式の最新料金は https://docs.claude.com で確認すること
# CLAUDE_PRICE_INPUT=3.0
# CLAUDE_PRICE_OUTPUT=15.0
# JPY_PER_USD=150

# === S2.5で使用予定（未使用のためコメントアウト） ===
# WP_API_BASE_URL=https://shop.tenemos.jp/apps/note/wp-json/wp/v2
# WP_API_USERNAME=your_username
# WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
